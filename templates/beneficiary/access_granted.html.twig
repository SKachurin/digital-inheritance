{% extends 'base.html.twig' %}

{% block content %}
    <style>
        .secret-envelope-page {
            padding: 4rem 1rem 3rem;
        }

        .secret-envelope-wrap {
            max-width: 980px;
            margin: 0 auto;
        }

        .secret-envelope-card {
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid rgba(0, 0, 0, 0.08);
            border-radius: 14px;
            padding: 2rem;
            margin-top: 8em;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            backdrop-filter: blur(4px);
        }

        .secret-envelope-title {
            font-size: 2.1rem;
            line-height: 1.2;
            margin: 0 0 2rem;
            font-weight: 700;
        }

        .secret-envelope-subtitle {
            font-size: 1.8rem;
            line-height: 1.25;
            margin: 0 0 0.75rem;
            font-weight: 700;
        }

        .secret-envelope-text {
            font-size: 1.05rem;
            line-height: 1.6;
            margin: 0 0 1.5rem;
            color: #222;
        }

        .secret-envelope-flashes {
            max-width: 980px;
            margin: 1.5rem auto 0;
        }

        .encrypted-box {
            margin-bottom: 1.5rem;
            padding: 1rem;
            border: 1px solid #ced4da;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
        }

        .encrypted-block {
            position: relative;
            overflow: hidden;
            transition: max-height 0.4s ease;
        }

        .encrypted-block.collapsed {
            max-height: 17rem;
        }

        .encrypted-block.expanded {
            max-height: 2000px;
        }

        .fade-overlay {
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            height: 5rem;
            background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,1));
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .encrypted-block.expanded .fade-overlay {
            opacity: 0;
        }

        .show-all-btn {
            margin-bottom: 1.5rem;
        }

        .secret-envelope-page textarea.form-control {
            min-height: 5rem;
            resize: vertical;
            white-space: pre-wrap;
            word-break: break-word;
            font-family: inherit;
            font-size: 0.98rem;
            line-height: 1.45;
        }

        .decoded-note textarea.form-control {
            min-height: 14rem;
        }

        .secret-envelope-page input.form-control,
        .secret-envelope-page textarea.form-control,
        .secret-envelope-page select.form-control {
            border-radius: 10px;
        }

        .secret-envelope-page .btn {
            border-radius: 10px;
        }

        .secret-envelope-note {
            margin-top: 1.5rem;
            padding: 1.25rem 1.5rem;
            border-radius: 10px;
        }

        @media (max-width: 768px) {
            .secret-envelope-page {
                padding: 2rem 0.75rem 2rem;
            }

            .secret-envelope-card {
                padding: 1.25rem;
            }

            .secret-envelope-title {
                font-size: 1.65rem;
            }

            .secret-envelope-subtitle {
                font-size: 1.4rem;
            }

            .secret-envelope-text {
                font-size: 1rem;
            }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const block = document.getElementById('encrypted-block');
            const btn = document.getElementById('show-all-btn');

            if (!block || !btn) {
                return;
            }

            btn.addEventListener('click', function () {
                block.classList.remove('collapsed');
                block.classList.add('expanded');
                btn.style.display = 'none';
            });
        });
    </script>

    <section class="secret-envelope-page">
        <div class="secret-envelope-wrap">
            <div class="secret-envelope-card">
                <h1 class="secret-envelope-title">
                    {{ 'header.envelope_from'|trans }} {{ customerFullName }} {{ 'header.for'|trans }} {{ beneficiaryFullName }}
                </h1>

                {% if not decodedNote %}
                    <h2 class="secret-envelope-subtitle">
                        {{ 'header.decrypt_to_read'|trans }}
                    </h2>

                    <p class="secret-envelope-text">
                        {{ 'enter_answer'|trans }}
                    </p>

                    {% if customerCongrats is defined and customerCongrats %}
                        <div class="alert alert-info">{{ customerCongrats }}</div>
                    {% endif %}

                    {{ form_start(form) }}

                    <div class="encrypted-box">
                        <div id="encrypted-block" class="encrypted-block collapsed">
                            {{ form_row(form.beneficiaryTextAnswerOne) }}
                            {{ form_row(form.beneficiaryTextAnswerOneKms2) }}
                            {{ form_row(form.beneficiaryTextAnswerOneKms3) }}
                            {{ form_row(form.beneficiaryTextAnswerTwo) }}
                            {{ form_row(form.beneficiaryTextAnswerTwoKms2) }}
                            {{ form_row(form.beneficiaryTextAnswerTwoKms3) }}

                            <div class="fade-overlay"></div>
                        </div>
                    </div>

                    <button type="button" id="show-all-btn" class="btn btn-outline-dark show-all-btn">
                        {{ 'show_all'|trans }}
                    </button>

                    {{ form_row(form.beneficiaryFirstQuestion) }}
                    {{ form_row(form.beneficiaryFirstQuestionAnswer) }}
                    {{ form_row(form.beneficiarySecondQuestion) }}
                    {{ form_row(form.beneficiarySecondQuestionAnswer) }}
                    {{ form_row(form.submit) }}

                    {{ form_end(form) }}
                {% endif %}

                {% if decodedNote %}
                    <div class="decoded-note">
                        <h2 class="secret-envelope-subtitle">
                            {{ 'header.here_is_your_data'|trans }}
                        </h2>

                        <p class="secret-envelope-text">
                            {{ 'header.save_it'|trans }}
                        </p>

                        {% if customerCongrats is defined and customerCongrats %}
                            <div class="alert alert-info">{{ customerCongrats }}</div>
                        {% endif %}

                        {{ form_start(form) }}
                        {{ form_row(form.customerText) }}
                        {{ form_row(form.customerTextKMS2) }}
                        {{ form_row(form.customerTextKMS3) }}

                        <div class="alert alert-success secret-envelope-note">
                            {{ 'header.link_will_expire'|trans|nl2br }}
                        </div>
                        {{ form_end(form) }}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="secret-envelope-flashes">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    </section>
{% endblock %}