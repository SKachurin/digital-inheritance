{% extends '/user/dashboard/layout.html.twig' %}
{% block dashboard_main %}
    <style>
        .form-container {
            padding-top: 4em;
        }
        .form-header {
            margin-bottom: 1em;
        }
        .button-group {
            display: flex;
            align-items: center;
            margin-top: 0.5em;
        }
        .button-group a {
            margin-left: 1em;
        }
        .divider {
            font-size: 1.5em;
            display: flex;
            align-items: center;
        }
        .divider::before,
        .divider::after {
            flex: 1;
            content: '';
            padding: 1px;
            background-color: #bbbb;
            margin: 2em !important;
        }
        #box {
            margin-bottom: 1.5rem;
            padding: 0.5rem;
            border: 1px solid #ced4da;
            border-radius: 6px;
            box-shadow: 0 2px 4px rgba(0, 0, 0, .1);
            background: rgba(255, 255, 255, .9);
            transition: background-color .3s ease;
        }
        #box:hover {
            background-color: #e9ecef;
        }

        #encrypting-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255, 255, 255, .9);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .spinner {
            border: 6px solid #ccc;
            border-top: 6px solid #333;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            100% {
                transform: rotate(360deg);
            }
        }
    </style>

    <div class="transactions-section">
        <h2 style="padding-top: 2em;">{{ 'dashboard.create_your_secure_envelope'|trans }}</h2>
        <p>{{ 'create_your_secure_envelope_text'|trans |nl2br }}</p>

{#        <div class="tooltip_text mb-4">{{ 'dashboard.create_your_secure_envelope_tip'|trans }}</div>#}

        <!-- Toggle Encrypt in Browser (Default On) -->
        <div class="form-check form-switch mb-4">
            <input class="form-check-input" type="checkbox" id="frontendEncrypted" checked disabled>
            <label class="form-check-label" for="frontendEncrypted">
                {{ 'dashboard.create_your_secure_envelope_switch'|trans|raw }}
            </label>
        </div>

        {{ form_start(form) }}
        {{ form_row(form.customerText) }}

        <div class="divider">{{ 'your_questions'|trans }}</div>
        <p>{{ 'your_questions_explain'|trans }}</p>
        {{ form_row(form.customerFirstQuestion) }}
        {{ form_row(form.customerFirstQuestionAnswer) }}
        {{ form_row(form.customerSecondQuestion) }}
        {{ form_row(form.customerSecondQuestionAnswer) }}

        {{ form_row(form._token) }}

        <div class="divider">{{ 'heir_questions'|trans }}</div>
        <p>{{ 'heir_questions_explain'|trans }}</p>

        <script src="https://cdn.jsdelivr.net/npm/argon2-browser@1.18.0/dist/argon2-bundled.min.js"></script>
        <script>
            async function sha256_b64_utf8(str) {
                const data = new TextEncoder().encode(str);
                const buf  = await crypto.subtle.digest('SHA-256', data);
                return btoa(String.fromCharCode(...new Uint8Array(buf)));
            }
        </script>
        <script>
            (() => {
                const CFG = Object.freeze({
                    debug: false,                // only affects console logging
                    wrapEndpoint: '/api/kms/wrap',
                    maxReplicas: 3,
                    argon: { time: 5, mem: 65536, parallelism: 1, hashLen: 32 },
                });

                const log = (...a) => CFG.debug && console.log('[FE-ENC]', ...a);

                // ---------- utils ----------
                const te = new TextEncoder();

                function qs(sel, root = document) { return root.querySelector(sel); }
                function byId(id) { return document.getElementById(id); }

                function bytesToB64(bytes) {
                    // safe chunking (avoids call stack overflow)
                    let bin = '';
                    const chunk = 0x8000;
                    for (let i = 0; i < bytes.length; i += chunk) {
                        bin += String.fromCharCode(...bytes.subarray(i, i + chunk));
                    }
                    return btoa(bin);
                }

                function b64ToBytes(b64) {
                    const bin = atob(b64);
                    const out = new Uint8Array(bin.length);
                    for (let i = 0; i < bin.length; i++) out[i] = bin.charCodeAt(i);
                    return out;
                }

                async function sha256b64(str) {
                    const buf = await crypto.subtle.digest('SHA-256', te.encode(str));
                    return bytesToB64(new Uint8Array(buf));
                }

                function setHidden(form, name, value) {
                    let el = qs(`[name="${CSS.escape(name)}"]`, form);
                    if (!el) {
                        el = document.createElement('input');
                        el.type = 'hidden';
                        el.name = name;
                        form.appendChild(el);
                    }
                    el.value = value;
                }

                function showOverlay(overlay, on) {
                    if (!overlay) return;
                    overlay.style.display = on ? 'flex' : 'none';
                }

                // ---------- crypto primitives ----------
                async function genDek() {
                    const raw = crypto.getRandomValues(new Uint8Array(32));
                    const key = await crypto.subtle.importKey('raw', raw, 'AES-GCM', false, ['encrypt', 'decrypt']);
                    return { raw, key };
                }

                async function aesGcmEncryptToB64(key, plaintext) {
                    const iv = crypto.getRandomValues(new Uint8Array(12));
                    const ct = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, key, te.encode(plaintext));
                    return {
                        c_b64: bytesToB64(new Uint8Array(ct)),
                        iv_b64: bytesToB64(iv),
                    };
                }

                async function argon2H(answer) {
                    const salt = crypto.getRandomValues(new Uint8Array(16));
                    const r = await argon2.hash({
                        pass: te.encode(answer),
                        salt,
                        time: CFG.argon.time,
                        mem: CFG.argon.mem,
                        parallelism: CFG.argon.parallelism,
                        hashLen: CFG.argon.hashLen,
                        type: argon2.ArgonType.Argon2id,
                        raw: true,
                    });
                    return { h: new Uint8Array(r.hash), salt };
                }

                async function hkdfAesGcmKeyFromH(hBytes, infoStr) {
                    const hkdfKey = await crypto.subtle.importKey('raw', hBytes, 'HKDF', false, ['deriveKey']);
                    return crypto.subtle.deriveKey(
                        {
                            name: 'HKDF',
                            hash: 'SHA-256',
                            salt: new Uint8Array([]),
                            info: te.encode(infoStr),
                        },
                        hkdfKey,
                        { name: 'AES-GCM', length: 256 },
                        false,
                        ['encrypt']
                    );
                }

                async function innerWrapDek(dekRaw, wrapKey, userId, answerFp) {
                    const ivInner = crypto.getRandomValues(new Uint8Array(12));
                    const aad = te.encode(`u=${userId}|fp=${answerFp}`);
                    const ct = await crypto.subtle.encrypt(
                        { name: 'AES-GCM', iv: ivInner, additionalData: aad },
                        wrapKey,
                        dekRaw
                    );

                    const ctBytes = new Uint8Array(ct);
                    const blob = new Uint8Array(ivInner.length + ctBytes.length);
                    blob.set(ivInner, 0);
                    blob.set(ctBytes, ivInner.length);
                    return bytesToB64(blob);
                }

                // ---------- network ----------
                async function wrapWithKMS(kmsId, innerB64, hB64, answer_fp) {
                    try {
                        const res = await fetch('/api/kms/wrap', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            credentials: 'same-origin',
                            body: JSON.stringify({
                                kms_id: "kms" + kmsId,
                                inner_b64: innerB64,
                                h_b64: hB64,
                                answer_fp
                            })
                        });

                        const j = await res.json().catch(() => null);

                        if (!res.ok || !j || !j.w_b64) {
                            console.warn('KMS wrap failed for KMS', kmsId, res.status, j);
                            return null;
                        }

                        return j.w_b64;
                    } catch (e) {
                        console.warn('KMS wrap exception for KMS', kmsId, e);
                        return null;
                    }
                }

                // ---------- orchestration ----------
                function readValues(ids) {
                    const get = (id) => (byId(id)?.value ?? '').trim();
                    return Object.fromEntries(Object.entries(ids).map(([k, id]) => [k, get(id)]));
                }

                function validateDoubleEntry(value, repeat, label) {
                    if (value && repeat && value !== repeat) {
                        throw new Error(`${label} mismatch`);
                    }
                }

                async function buildAllPayloads({ userId, note, answers, namesBySlot, enc, dekRaw }) {
                    const results = []; // { hiddenName, payloadJson }
                    let any = false;

                    for (const [slot, answer] of Object.entries(answers)) {
                        if (!answer) continue;

                        const { h, salt } = await argon2H(answer);
                        const hB64 = bytesToB64(h);
                        const sB64 = bytesToB64(salt);

                        const answerFp = await sha256b64(`${enc.c_b64}.${enc.iv_b64}.${sB64}`);
                        const infoStr = `inner-wrap-v1|u=${userId}|fp=${answerFp}`;

                        const wrapKey = await hkdfAesGcmKeyFromH(h, infoStr);
                        const innerB64 = await innerWrapDek(dekRaw, wrapKey, userId, answerFp);

                        // try each replica; only add payloads for successful wraps
                        for (let kmsId = 1; kmsId <= CFG.maxReplicas; kmsId++) {
                            const w_b64 = await wrapWithKMS(kmsId, innerB64, hB64, answerFp);
                            if (!w_b64) continue;

                            any = true;

                            const payload = JSON.stringify({
                                kms_id: `kms${kmsId}`,
                                c: enc.c_b64,
                                iv: enc.iv_b64,
                                w: w_b64,
                                s: sB64,
                            });

                            const hiddenName = namesBySlot[slot][kmsId - 1];
                            results.push({ hiddenName, payload });
                        }
                    }

                    return { anySucceeded: any, payloads: results };
                }

                function init() {
                    const form = qs('form[name="{{ form.vars.name }}"]');
                    if (!form) return;

                    const overlay = byId('encrypting-overlay');
                    const toggle = byId('frontendEncrypted');

                    // map ids (Twig)
                    const IDS = {
                        note: "{{ form.customerText.vars.id }}",
                        a1: "{{ form.customerFirstQuestionAnswer.vars.id }}_first",
                        a1r:"{{ form.customerFirstQuestionAnswer.vars.id }}_second",
                        a2: "{{ form.customerSecondQuestionAnswer.vars.id }}_first",
                        b1: "{{ form.beneficiaryFirstQuestionAnswer.vars.id }}_first",
                        b1r:"{{ form.beneficiaryFirstQuestionAnswer.vars.id }}_second",
                        b2: "{{ form.beneficiarySecondQuestionAnswer.vars.id }}_first",
                    };

                    const NAMES = {
                        a1: ["{{ form.customerTextAnswerOne.vars.full_name }}","{{ form.customerTextAnswerOneKms2.vars.full_name }}","{{ form.customerTextAnswerOneKms3.vars.full_name }}"],
                        a2: ["{{ form.customerTextAnswerTwo.vars.full_name }}","{{ form.customerTextAnswerTwoKms2.vars.full_name }}","{{ form.customerTextAnswerTwoKms3.vars.full_name }}"],
                        b1: ["{{ form.beneficiaryTextAnswerOne.vars.full_name }}","{{ form.beneficiaryTextAnswerOneKms2.vars.full_name }}","{{ form.beneficiaryTextAnswerOneKms3.vars.full_name }}"],
                        b2: ["{{ form.beneficiaryTextAnswerTwo.vars.full_name }}","{{ form.beneficiaryTextAnswerTwoKms2.vars.full_name }}","{{ form.beneficiaryTextAnswerTwoKms3.vars.full_name }}"],
                    };

                    const userId = {{ app.user.id }};

                    form.addEventListener('submit', async (ev) => {
                        // if toggle missing or off -> normal submit
                        if (!toggle || !toggle.checked) return;

                        ev.preventDefault();
                        showOverlay(overlay, true);

                        try {
                            if (!crypto?.subtle) throw new Error('WebCrypto not available');

                            const v = readValues(IDS);
                            validateDoubleEntry(v.a1, v.a1r, 'Customer answer #1');
                            validateDoubleEntry(v.b1, v.b1r, 'Heir answer #1');

                            if (!v.note || !v.a1 || !v.b1) {
                                throw new Error('Missing required fields');
                            }

                            const { key: dekKey, raw: dekRaw } = await genDek();
                            const enc = await aesGcmEncryptToB64(dekKey, v.note);

                            // mark FE encryption
                            setHidden(form, "{{ form.frontendEncrypted.vars.full_name }}", '1');

                            const answers = { a1: v.a1, a2: v.a2, b1: v.b1, b2: v.b2 };
                            const { anySucceeded, payloads } = await buildAllPayloads({
                                userId, note: v.note, answers, namesBySlot: NAMES, enc, dekRaw
                            });

                            if (!anySucceeded) {
                                throw new Error('KMS wrap failed for all replicas (nothing saved)');
                            }

                            for (const p of payloads) {
                                setHidden(form, p.hiddenName, p.payload);
                            }

                            // optional: clear plaintext before submit (so browser doesn’t keep it)
                            // byId(IDS.note).value = '';
                            // byId(IDS.a1).value = '';
                            // byId(IDS.a1r).value = '';
                            // byId(IDS.b1).value = '';
                            // byId(IDS.b1r).value = '';

                            showOverlay(overlay, false);
                            form.submit();
                        } catch (err) {
                            showOverlay(overlay, false);
                            alert(`Encryption failed: ${err?.message || err}`);
                            log('submit error', err);
                        }
                    }, { passive: false });
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', init, { once: true });
                } else {
                    init();
                }
            })();
        </script>



        {{ form_end(form) }}
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div id="encrypting-overlay">
        <div class="overlay-content" style="text-align:center;">
            <h2>{{ 'overlay_encrypting'|trans }} </h2>
            <p>{{ 'overlay_wait'|trans }} </p>
            <div class="spinner"></div>
        </div>
    </div>
{% endblock %}
